#!/usr/bin/env python3
import sys, os, re, subprocess, tempfile

URL = sys.argv[1] if len(sys.argv) > 1 else ''
LANG = sys.argv[2] if len(sys.argv) > 2 else 'ru'
COOKIES = '/root/.openclaw/youtube_cookies.txt'

if not URL:
    print('Usage: yt-transcript <url> [lang]')
    sys.exit(1)

with tempfile.TemporaryDirectory() as tmpdir:
    output_path = os.path.join(tmpdir, 'sub')
    cmd = [
        'yt-dlp',
        '--cookies', COOKIES,
        '--js-runtimes', 'node',
        '--write-auto-sub',
        '--sub-lang', f'{LANG},ru,en',
        '--skip-download', '--no-playlist', '--quiet',
        URL, '-o', output_path,
    ]
    subprocess.run(cmd, capture_output=True, text=True, timeout=60)

    vtt_files = [f for f in os.listdir(tmpdir) if f.endswith('.vtt')]
    if not vtt_files:
        print('ERROR: No transcript found.')
        sys.exit(1)

    content = open(os.path.join(tmpdir, vtt_files[0]), encoding='utf-8').read()
    lines = content.split('\n')
    out = []
    for line in lines:
        line = line.strip()
        if not line or '-->' in line or line.startswith('WEBVTT') or line.startswith('Kind:') or line.startswith('Language:') or re.match(r'^\d+$', line):
            continue
        line = re.sub(r'<[^>]+>', '', line).strip()
        if line and (not out or out[-1] != line):
            out.append(line)
    print(' '.join(out))
